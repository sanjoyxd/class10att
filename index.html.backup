<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">

    <title>Class X Attendance - Assam Brilliant Academy</title>

    

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>



    <style>

        body {

            background-color: #f4f7f6;

            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;

            padding-bottom: 80px; 

        }

        

        /* Login Screen Styling */

        #login-screen {

            height: 100vh;

            display: flex;

            align-items: center;

            justify-content: center;

            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);

        }

        .login-card {

            background: white;

            padding: 2.5rem;

            border-radius: 15px;

            box-shadow: 0 10px 25px rgba(0,0,0,0.2);

            width: 90%;

            max-width: 400px;

            text-align: center;

        }

        .login-logo {

            font-size: 3rem;

            color: #2a5298;

            margin-bottom: 1rem;

        }



        /* Main App Styling */

        #main-app { display: none; }

        

        .header-banner {

            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);

            color: white;

            padding: 2rem 1rem;

            border-radius: 0 0 15px 15px;

            box-shadow: 0 4px 10px rgba(0,0,0,0.1);

            position: relative;

        }

        .logout-btn {

            position: absolute;

            top: 15px;

            right: 15px;

            background: rgba(255,255,255,0.2);

            color: white;

            border: none;

            padding: 5px 15px;

            border-radius: 20px;

            font-size: 0.85rem;

        }

        .logout-btn:hover { background: rgba(255,255,255,0.3); }



        .nav-pills .nav-link {

            color: #495057;

            font-weight: 600;

            margin: 0.2rem;

            border-radius: 30px;

        }

        .nav-pills .nav-link.active {

            background-color: #2a5298;

            color: white;

            box-shadow: 0 4px 6px rgba(42, 82, 152, 0.3);

        }

        .tab-content-section { display: none; }

        .tab-content-section.active { display: block; animation: fadeIn 0.3s; }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }



        .attendance-row {

            padding: 12px 10px;

            border-bottom: 1px solid #e9ecef;

            transition: background-color 0.2s;

        }

        .attendance-row:hover { background-color: #f8f9fa; }

        .form-check-input {

            width: 1.8em;

            height: 1.8em;

            margin-top: 0;

            cursor: pointer;

        }

        .student-label {

            cursor: pointer;

            font-size: 1.1rem;

            margin-left: 15px;

            user-select: none;

            width: 100%;

        }

        .stat-card {

            background: white;

            border-radius: 10px;

            padding: 1.5rem;

            border-left: 5px solid #2a5298;

            box-shadow: 0 2px 8px rgba(0,0,0,0.05);

            height: 100%;

        }

        .table-responsive {

            background: white;

            border-radius: 10px;

            box-shadow: 0 2px 8px rgba(0,0,0,0.05);

            padding: 10px;

        }

        th { color: #6c757d; text-transform: uppercase; font-size: 0.85rem; }

    </style>

</head>

<body>



<div id="login-screen">

    <div class="login-card">

        <i class="fas fa-user-shield login-logo"></i>

        <h3 class="fw-bold mb-1">Teacher Login</h3>

        <p class="text-muted small mb-4">Assam Brilliant Academy</p>

        

        <div class="form-floating mb-3">

            <input type="text" class="form-control" id="username" placeholder="Username" autocomplete="off">

            <label for="username">Username</label>

        </div>

        <div class="form-floating mb-4">

            <input type="password" class="form-control" id="password" placeholder="Password">

            <label for="password">Password</label>

        </div>

        

        <button class="btn btn-primary w-100 py-3 fw-bold rounded-pill" onclick="attemptLogin()">

            <i class="fas fa-sign-in-alt me-2"></i> Access Portal

        </button>

        <p id="login-error" class="text-danger mt-3 small fw-bold" style="display: none;">Invalid credentials. Try again.</p>

    </div>

</div>



<div id="main-app">

    <div class="header-banner text-center mb-4">

        <button class="logout-btn" onclick="logout()"><i class="fas fa-sign-out-alt me-1"></i> Lock</button>

        <h1 class="h3 fw-bold mb-1"><i class="fas fa-graduation-cap me-2"></i>Assam Brilliant Academy</h1>

        <p class="mb-0 text-light opacity-75">Class X - Attendance Portal</p>

    </div>



    <div class="container">

        <ul class="nav nav-pills justify-content-center mb-4 flex-nowrap overflow-auto pb-2" style="white-space: nowrap;">

            <li class="nav-item">

                <button class="nav-link active tab-btn" onclick="switchTab('daily')"><i class="fas fa-calendar-check me-2"></i>Daily</button>

            </li>

            <li class="nav-item">

                <button class="nav-link tab-btn" onclick="switchTab('reports')"><i class="fas fa-chart-bar me-2"></i>Reports</button>

            </li>

            <li class="nav-item">

                <button class="nav-link tab-btn" onclick="switchTab('students')"><i class="fas fa-users-cog me-2"></i>Manage</button>

            </li>

        </ul>

        

        <div id="daily" class="tab-content-section active">

            <div class="card border-0 shadow-sm mb-4">

                <div class="card-body bg-light rounded">

                    <div class="row g-3 align-items-end">

                        <div class="col-12 col-md-6">

                            <label class="form-label fw-bold text-muted small">Select Date</label>

                            <input type="date" class="form-control form-control-lg" id="attendance-date" onchange="loadDailyAttendance()">

                        </div>

                        <div class="col-6 col-md-3">

                            <button class="btn btn-outline-success w-100 py-2" onclick="markAll(true)"><i class="fas fa-check-double me-1"></i> All Present</button>

                        </div>

                        <div class="col-6 col-md-3">

                            <button class="btn btn-outline-danger w-100 py-2" onclick="markAll(false)"><i class="fas fa-times me-1"></i> All Absent</button>

                        </div>

                    </div>

                </div>

            </div>

            

            <div class="card border-0 shadow-sm mb-4">

                <div class="card-body p-0" id="attendance-list"></div>

            </div>

            

            <button class="btn btn-primary btn-lg w-100 shadow rounded-pill py-3 fw-bold" onclick="saveDailyAttendance()">

                <i class="fas fa-save me-2"></i> Save Attendance for <span id="display-date">Today</span>

            </button>

            

            <div id="save-msg" class="alert alert-success mt-3 text-center fw-bold" style="display: none;">

                <i class="fas fa-check-circle me-2"></i> Attendance Saved Successfully!

            </div>

        </div>



        <div id="reports" class="tab-content-section">

            <div class="card border-0 shadow-sm mb-4">

                <div class="card-body bg-light rounded d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-3">

                    <div class="flex-grow-1">

                        <label class="form-label fw-bold text-muted small">Select Report Month</label>

                        <input type="month" class="form-control form-control-lg" id="report-month" onchange="generateReport()">

                    </div>

                    <div class="d-flex gap-2">

                        <button class="btn btn-secondary py-2 px-3" onclick="generateReport()"><i class="fas fa-sync-alt"></i></button>

                        <button class="btn btn-success py-2 px-3 fw-bold" onclick="exportToExcel()"><i class="fas fa-file-excel me-2"></i>Export Excel</button>

                    </div>

                </div>

            </div>



            <div class="row g-3 mb-4">

                <div class="col-12 col-md-4">

                    <div class="stat-card text-center">

                        <p class="text-muted small fw-bold mb-1">ACADEMIC SESSION</p>

                        <h3 class="text-primary mb-0" id="summary-session">----</h3>

                    </div>

                </div>

                <div class="col-6 col-md-4">

                    <div class="stat-card text-center" style="border-left-color: #2ecc71;">

                        <p class="text-muted small fw-bold mb-1">OPENED (MONTH)</p>

                        <h3 class="text-success mb-0" id="summary-monthly-opened">0</h3>

                    </div>

                </div>

                <div class="col-6 col-md-4">

                    <div class="stat-card text-center" style="border-left-color: #f39c12;">

                        <p class="text-muted small fw-bold mb-1">OPENED (ANNUAL)</p>

                        <h3 class="text-warning mb-0" id="summary-annual-opened">0</h3>

                    </div>

                </div>

            </div>

            

            <div class="table-responsive border-0">

                <table class="table table-hover table-striped align-middle mb-0">

                    <thead class="table-light">

                        <tr>

                            <th>Roll</th>

                            <th>Name</th>

                            <th class="text-center">Monthly</th>

                            <th class="text-center">Annual</th>

                        </tr>

                    </thead>

                    <tbody id="report-body"></tbody>

                </table>

            </div>

        </div>



        <div id="students" class="tab-content-section">

            <div class="card border-0 shadow-sm mb-4">

                <div class="card-header bg-white py-3">

                    <h5 class="mb-0 fw-bold"><i class="fas fa-user-plus me-2 text-primary"></i>Add New Student</h5>

                </div>

                <div class="card-body">

                    <div class="row g-3">

                        <div class="col-12 col-md-3">

                            <input type="number" class="form-control" id="roll-no" placeholder="Roll No." required>

                        </div>

                        <div class="col-12 col-md-6">

                            <input type="text" class="form-control" id="student-name" placeholder="Full Name" required>

                        </div>

                        <div class="col-12 col-md-3">

                            <button class="btn btn-primary w-100" onclick="addStudent()"><i class="fas fa-plus me-2"></i>Add</button>

                        </div>

                    </div>

                </div>

            </div>

            

            <div class="table-responsive border-0">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">

                        <tr>

                            <th style="width: 15%;">Roll</th>

                            <th>Student Name</th>

                            <th style="width: 25%;" class="text-end">Actions</th>

                        </tr>

                    </thead>

                    <tbody id="student-list"></tbody>

                </table>

            </div>

        </div>

    </div>

</div>



<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>



<script>

    // --- LOGIN LOGIC ---

    function checkSession() {

        if(sessionStorage.getItem('aba_auth_token') === 'verified') {

            document.getElementById('login-screen').style.display = 'none';

            document.getElementById('main-app').style.display = 'block';

            initializeAppData(); // Load data only after login

        } else {

            document.getElementById('login-screen').style.display = 'flex';

            document.getElementById('main-app').style.display = 'none';

        }

    }



    function attemptLogin() {

        const user = document.getElementById('username').value.trim();

        const pass = document.getElementById('password').value.trim();

        const errorMsg = document.getElementById('login-error');



        // Allow 'Enter' key submission

        if (user === 'sanjoyxd' && pass === 'Aba@2026') {

            sessionStorage.setItem('aba_auth_token', 'verified');

            errorMsg.style.display = 'none';

            document.getElementById('username').value = '';

            document.getElementById('password').value = '';

            checkSession();

        } else {

            errorMsg.style.display = 'block';

            // Slight shake animation could go here

        }

    }



    function logout() {

        sessionStorage.removeItem('aba_auth_token');

        checkSession();

    }



    // Allow Enter key on password field

    document.getElementById('password').addEventListener('keypress', function (e) {

        if (e.key === 'Enter') attemptLogin();

    });



    // --- APP LOGIC (Only runs if logged in) ---

    let students = [];

    let attendanceData = {};



    function initializeAppData() {

        // --- DATABASE ---

        students = JSON.parse(localStorage.getItem('aba_class10_students'));

        attendanceData = JSON.parse(localStorage.getItem('aba_class10_attendance')) || {};



        if (!students || students.length === 0) {

            students = [

                { roll: "1", name: "PARISMITA RAHA ROY" }, { roll: "2", name: "PRIYANGSHU MANDAL" },

                { roll: "3", name: "PRACHI SAHA" }, { roll: "4", name: "ANANYA BARMAN" },

                { roll: "5", name: "ADITA GHOSH" }, { roll: "6", name: "SNIGHDHA GHOSH" },

                { roll: "7", name: "DEEPJYOTI GAYARY" }, { roll: "8", name: "CHAYANKA SHEKHAR NATH" },

                { roll: "9", name: "SANTANU BASAK" }, { roll: "10", name: "SAYAN SAHA" },

                { roll: "11", name: "SUBHADEEP SAHA" }, { roll: "12", name: "RITIKA SAHA" },

                { roll: "13", name: "IRFAN HABIB BHUYAN" }, { roll: "14", name: "TANISHA BARMAN" },

                { roll: "15", name: "OM DEKA" }, { roll: "16", name: "MUNALI SAH" },

                { roll: "17", name: "AMINA SULTANA" }, { roll: "18", name: "ASIF PRAMANIK" },

                { roll: "19", name: "SHAKIB AHMED" }, { roll: "20", name: "NAFISA KHANAM" },

                { roll: "21", name: "SOURAV DAS" }, { roll: "22", name: "NISHAN BORO (LEFT)" },

                { roll: "23", name: "KRISHNANGI PARASAR" }

            ];

            localStorage.setItem('aba_class10_students', JSON.stringify(students));

        }



        // --- INIT ---

        const today = new Date();

        document.getElementById('attendance-date').valueAsDate = today;

        const currentYearStr = today.getFullYear();

        const currentMonthStr = String(today.getMonth() + 1).padStart(2, '0');

        document.getElementById('report-month').value = `${currentYearStr}-${currentMonthStr}`;

        

        renderStudents();

        loadDailyAttendance();

    }



    // --- TABS ---

    function switchTab(tabId) {

        document.querySelectorAll('.tab-content-section').forEach(tab => tab.classList.remove('active'));

        document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));

        document.getElementById(tabId).classList.add('active');

        event.currentTarget.classList.add('active');

        if(tabId === 'reports') generateReport();

        if(tabId === 'daily') loadDailyAttendance();

    }



    // --- MANAGE STUDENTS ---

    function addStudent() {

        const roll = document.getElementById('roll-no').value.trim();

        const name = document.getElementById('student-name').value.trim().toUpperCase();

        if (!roll || !name) return alert('Please enter both Roll Number and Name.');

        if (students.find(s => s.roll === roll)) return alert('This Roll Number already exists.');

        students.push({ roll, name });

        saveAndRenderStudents();

        document.getElementById('roll-no').value = '';

        document.getElementById('student-name').value = '';

    }



    function editStudent(oldRoll) {

        const student = students.find(s => s.roll === oldRoll);

        if(!student) return;

        const newRoll = prompt("Edit Roll Number:", student.roll);

        if(newRoll === null || newRoll.trim() === '') return;

        if(newRoll !== student.roll && students.find(s => s.roll === newRoll)) return alert("Roll Number already in use.");

        const newName = prompt("Edit Student Name:", student.name);

        if(newName === null || newName.trim() === '') return;

        student.roll = newRoll.trim();

        student.name = newName.trim().toUpperCase();

        saveAndRenderStudents();

    }



    function removeStudent(roll) {

        if(confirm('Remove this student? Attendance history will be lost.')) {

            students = students.filter(s => s.roll !== roll);

            saveAndRenderStudents();

        }

    }



    function saveAndRenderStudents() {

        students.sort((a, b) => parseInt(a.roll) - parseInt(b.roll));

        localStorage.setItem('aba_class10_students', JSON.stringify(students));

        renderStudents();

    }



    function renderStudents() {

        const tbody = document.getElementById('student-list');

        tbody.innerHTML = '';

        students.forEach(student => {

            tbody.innerHTML += `

                <tr>

                    <td><span class="badge bg-secondary rounded-pill px-3 py-2">${student.roll}</span></td>

                    <td class="fw-bold text-dark">${student.name}</td>

                    <td class="text-end">

                        <button class="btn btn-sm btn-outline-warning me-1" onclick="editStudent('${student.roll}')"><i class="fas fa-edit"></i></button>

                        <button class="btn btn-sm btn-outline-danger" onclick="removeStudent('${student.roll}')"><i class="fas fa-trash"></i></button>

                    </td>

                </tr>

            `;

        });

    }



    // --- DAILY ATTENDANCE ---

    function loadDailyAttendance() {

        const date = document.getElementById('attendance-date').value;

        const dateObj = new Date(date);

        const options = { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' };

        document.getElementById('display-date').innerText = dateObj.toLocaleDateString(undefined, options);

        

        const listDiv = document.getElementById('attendance-list');

        listDiv.innerHTML = '';



        if(students.length === 0) return listDiv.innerHTML = '<div class="p-4 text-center text-muted">No students found.</div>';



        const presentStudents = attendanceData[date] || [];



        students.forEach(student => {

            const isChecked = presentStudents.includes(student.roll) ? 'checked' : '';

            listDiv.innerHTML += `

                <div cla</html>
